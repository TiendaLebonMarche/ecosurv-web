--- 
import Company from '../../content/company.json' with { type: 'json' };
---

<footer class="bg-corporate-900 text-white">
  <div class="container-custom section">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-2xl font-bold text-primary-400 mb-4">ECOSURVEY</h3>
        <p class="text-corporate-300 mb-4">{Company.mision.substring(0, 120)}...</p>
        <div class="space-y-2 text-sm">
          <p>{Company.direccion}</p>
          <p>{Company.telefono}</p>
        </div>
      </div>
      <div>
        <h4 class="text-lg font-semibold mb-4">Servicios</h4>
        <ul class="space-y-2 text-corporate-300">
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Topografía con Drones</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Avalúos Catastrales</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Peritajes Judiciales</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Catastro Multipropósito</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-lg font-semibold mb-4">Contacto</h4>
        <ul class="space-y-2 text-corporate-300">
          <li>📧 {Company.email}</li>
          <li>📱 {Company.whatsapp}</li>
          <li>🌐 {Company.web}</li>
        </ul>
      </div>
      <div>
        <h4 class="text-lg font-semibold mb-4">Sigue</h4>
        <div class="flex space-x-4">
          <a href="https://instagram.com/{Company.instagram}" class="text-xl hover:text-primary-400" aria-label="Instagram">📸</a>
          <a href="https://facebook.com/{Company.facebook}" class="text-xl hover:text-primary-400" aria-label="Facebook">📘</a>
        </div>
        <p class="text-xs mt-4 text-corporate-400">© 2024 ECOSURVEY S.A.S. Todos los derechos reservados.</p>
      </div>
    </div>
  </div>
</footer>
