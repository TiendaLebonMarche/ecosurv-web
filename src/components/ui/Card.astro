---
interface Props {
  icon?: string;
  title: string;
  description: string;
  category?: string;
  href?: string;
  className?: string;
}

const {
  icon = '📌',
  title,
  description,
  category,
  href,
  className = '',
} = Astro.props as Props;
---

<article class:list={['card group h-full', className]}>
  <div class="flex h-full flex-col p-6">
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100 transition-colors group-hover:bg-primary-400">
      <span class="text-xl text-primary-600 transition-colors group-hover:text-white" aria-hidden="true">{icon}</span>
    </div>

    <h3 class="mb-3 text-xl font-bold text-corporate-900 transition-colors group-hover:text-primary-600">{title}</h3>
    <p class="mb-4 flex-grow text-corporate-600">{description}</p>

    {category && (
      <span class="inline-block rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary-700">
        {category}
      </span>
    )}

    {href && (
      <a
        href={href}
        class="mt-4 inline-flex text-sm font-semibold text-primary-600 transition-colors hover:text-primary-700"
      >
        Ver más
      </a>
    )}
  </div>
</article>
