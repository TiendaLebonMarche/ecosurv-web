---
interface Props {
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  rel?: string;
  className?: string;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'primary',
  size = 'md',
  href,
  target,
  rel,
  className = '',
  type = 'button',
} = Astro.props as Props;

const variantClass = variant === 'secondary' ? 'btn-secondary' : 'btn-primary';

const sizeClass =
  size === 'sm'
    ? 'px-4 py-2 text-sm'
    : size === 'lg'
      ? 'px-8 py-4 text-lg'
      : 'px-6 py-3 text-base';

const classes = [variantClass, sizeClass, className].join(' ').trim();
---

{
  href ? (
    <a href={href} target={target} rel={rel} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
