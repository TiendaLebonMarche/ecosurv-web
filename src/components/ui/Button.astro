---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  rel?: string;
  className?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  target,
  rel,
  className = '',
  type = 'button',
  disabled = false,
} = Astro.props as Props;

const variantClass =
  variant === 'secondary'
    ? 'btn-secondary'
    : variant === 'ghost'
      ? 'btn-ghost'
      : variant === 'outline'
        ? 'btn-outline'
        : 'btn-primary';

const sizeClass =
  size === 'sm'
    ? 'px-4 py-2 text-sm'
    : size === 'lg'
      ? 'px-8 py-4 text-lg'
      : 'px-6 py-3 text-base';

const classes = [
  variantClass,
  sizeClass,
  disabled && 'pointer-events-none opacity-60',
  className
].filter(Boolean).join(' ').trim();
---

{
  href ? (
    <a href={href} target={target} rel={rel} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled}>
      <slot />
    </button>
  )
}
