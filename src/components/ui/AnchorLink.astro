---
interface Props {
  href: string;
  className?: string;
  activeClass?: string;
}

const { href, className = '', activeClass = 'text-primary-600 font-bold' } = Astro.props as Props;
const isAnchor = href.startsWith('#');
const currentPath = Astro.url.pathname;
const isActive = !isAnchor && (href === currentPath || (href !== '/' && currentPath.startsWith(href)));
---

<a
  href={href}
  class:list={[
    "transition-colors hover:text-primary-600",
    className,
    isActive && activeClass
  ]}
  data-smooth-scroll={isAnchor ? 'true' : 'false'}
>
  <slot />
</a>

<script>
  document.querySelectorAll('a[data-smooth-scroll="true"]').forEach((link) => {
    link.addEventListener('click', (event) => {
      const anchor = link.getAttribute('href');
      if (!anchor?.startsWith('#')) return;

      const target = document.querySelector(anchor);
      if (!target) return;

      event.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
