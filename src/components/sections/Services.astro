---
import services from '../../content/services.json';

type ServiceItem = {
  id: string;
  titulo: string;
  descripcion: string;
  icono: string;
  categoria: 'topografia' | 'catastro' | 'petrolero' | 'peritajes';
};

const categories = [
  { key: 'all', label: 'Todos' },
  { key: 'topografia', label: 'Topografía y Geomática' },
  { key: 'catastro', label: 'Catastro y Avalúos' },
  { key: 'petrolero', label: 'Sector Petrolero e Infraestructura' },
  { key: 'peritajes', label: 'Peritajes y Asesoría Jurídica' },
];

const typedServices = services as ServiceItem[];

const iconMap: Record<string, string> = {
  drone: '🛰️',
  marker: '📍',
  map: '🗺️',
  water: '🌊',
  clipboard: '📋',
  certificate: '📜',
  document: '📄',
  oil: '🛢️',
  bolt: '⚡',
  road: '🛣️',
  scale: '⚖️',
  chart: '📈',
  gavel: '🔨',
};
---

<section id="servicios" class="section bg-corporate-50">
  <div class="container-custom">
    <div class="mb-10 text-center reveal">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary-600">Servicios especializados</p>
      <h2 class="mb-4 font-display text-3xl font-bold text-corporate-900 md:text-4xl">Soluciones integrales en topografía e ingeniería</h2>
      <p class="mx-auto max-w-3xl text-corporate-600">
        Atendemos proyectos técnicos en Bucaramanga y toda Colombia con precisión, respaldo legal y tecnología de punta.
      </p>
    </div>

    <div class="mb-8 flex flex-wrap gap-2 reveal" role="tablist" aria-label="Filtrar servicios por categoría">
      {categories.map((category, index) => (
        <button
          type="button"
          class={`service-filter rounded-full border px-4 py-2 text-sm font-semibold transition-colors ${
            index === 0
              ? 'border-primary-600 bg-primary-600 text-white'
              : 'border-corporate-300 bg-white text-corporate-700 hover:border-primary-400 hover:text-primary-600'
          }`}
          data-filter={category.key}
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
        >
          {category.label}
        </button>
      ))}
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {typedServices.map((service) => (
        <article
          class="card reveal service-card p-6"
          data-category={service.categoria}
          aria-labelledby={`${service.id}-title`}
        >
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-primary-50 text-2xl">
            {iconMap[service.icono] ?? '📌'}
          </div>
          <h3 id={`${service.id}-title`} class="mb-3 text-xl font-semibold text-corporate-900">{service.titulo}</h3>
          <p class="mb-4 text-sm leading-relaxed text-corporate-600">{service.descripcion}</p>
          <span class="inline-flex rounded-full bg-corporate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-corporate-700">
            {service.categoria}
          </span>
        </article>
      ))}
    </div>

    <div class="mt-10 text-center reveal">
      <a href="#contacto" class="btn-primary inline-flex">Solicitar cotización técnica</a>
    </div>
  </div>
</section>

<script>
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.service-filter'));
  const serviceCards = Array.from(document.querySelectorAll<HTMLElement>('.service-card'));

  const applyFilter = (filter: string) => {
    serviceCards.forEach((card) => {
      const category = card.dataset.category ?? '';
      const visible = filter === 'all' || category === filter;
      card.style.display = visible ? '' : 'none';
    });

    filterButtons.forEach((button) => {
      const selected = button.dataset.filter === filter;
      button.setAttribute('aria-selected', selected ? 'true' : 'false');
      button.classList.toggle('border-primary-600', selected);
      button.classList.toggle('bg-primary-600', selected);
      button.classList.toggle('text-white', selected);
      button.classList.toggle('border-corporate-300', !selected);
      button.classList.toggle('bg-white', !selected);
      button.classList.toggle('text-corporate-700', !selected);
    });
  };

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.dataset.filter ?? 'all';
      applyFilter(filter);
    });
  });
</script>
