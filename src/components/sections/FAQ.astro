---
import faqData from '../../content/faq.json';

type FaqItem = {
  pregunta: string;
  respuesta: string;
};

const items = faqData as FaqItem[];
---

<section id="faq" class="section bg-white">
  <div class="container-custom">
    <div class="mx-auto max-w-4xl reveal">
      <p class="mb-3 text-center text-sm font-semibold uppercase tracking-wider text-primary-600">Dudas comunes</p>
      <h2 class="mb-10 text-center font-display text-3xl font-bold text-corporate-900 md:text-4xl">
        Preguntas frecuentes sobre nuestros servicios
      </h2>

      <div class="space-y-4">
        {items.map((item, index) => (
          <details class="card p-5" open={index === 0}>
            <summary class="cursor-pointer list-none pr-8 text-base font-semibold text-corporate-900 transition-colors hover:text-primary-600">
              {item.pregunta}
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-corporate-600">{item.respuesta}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
