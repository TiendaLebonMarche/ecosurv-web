---
import Metrics from '../../content/metrics.json' with { type: 'json' };
---

<section id="inicio" class="relative flex min-h-screen items-center overflow-hidden bg-gradient-to-br from-neutral-950 via-neutral-900 to-primary-950">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(16,185,129,0.24),transparent_60%)]"></div>
    <div class="absolute -top-20 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-primary-500/20 blur-3xl animate-float"></div>
    <div class="float-particle absolute top-1/4 left-[12%] h-2 w-2 rounded-full bg-primary-300/60"></div>
    <div class="float-particle absolute top-2/3 right-[18%] h-3 w-3 rounded-full bg-accent-400/60" style="animation-delay: 0.8s;"></div>
    <div class="float-particle absolute top-[38%] right-[10%] h-2 w-2 rounded-full bg-primary-200/70" style="animation-delay: 1.4s;"></div>
  </div>

  <div class="container-custom relative z-10 py-20">
    <div class="mx-auto max-w-5xl text-center">
      <p class="mb-5 inline-flex items-center rounded-full border border-primary-300/30 bg-primary-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-primary-200">
        Topografía e ingeniería de precisión
      </p>

      <h1 class="text-balance font-display text-4xl font-extrabold leading-tight text-white md:text-6xl lg:text-7xl">
        Soluciones topográficas
        <span class="bg-gradient-to-r from-primary-300 via-primary-400 to-accent-400 bg-clip-text text-transparent"> premium, confiables y escalables</span>
      </h1>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-neutral-200 md:text-xl">
        Levantamientos con drones, avalúos, peritajes y consultoría catastral en Bucaramanga y toda Colombia.
        Diseño técnico, trazabilidad legal y ejecución impecable.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="#contacto" class="btn-primary">Solicitar cotización</a>
        <a href="#servicios" class="btn-secondary">Explorar servicios</a>
      </div>
    </div>

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <article class="glass p-5 text-center">
        <p class="text-2xl font-bold text-white">{Metrics.kilometrosMedidos}</p>
        <p class="mt-1 text-sm text-neutral-300">Kilómetros medidos</p>
      </article>
      <article class="glass p-5 text-center">
        <p class="text-2xl font-bold text-white">{Metrics.regionesAtendidas}</p>
        <p class="mt-1 text-sm text-neutral-300">Regiones atendidas</p>
      </article>
      <article class="glass p-5 text-center">
        <p class="text-2xl font-bold text-white">{Metrics.puntosGPS}</p>
        <p class="mt-1 text-sm text-neutral-300">Puntos GPS</p>
      </article>
      <article class="glass p-5 text-center">
        <p class="text-2xl font-bold text-white">{Metrics.sesionesIGAC}</p>
        <p class="mt-1 text-sm text-neutral-300">Sesiones IGAC</p>
      </article>
    </div>
  </div>
</section>
