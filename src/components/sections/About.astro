---
import metricsData from '../../content/metrics.json';
import companyData from '../../content/company.json';

type Metrics = {
  kilometrosMedidos: string;
  regionesAtendidas: string;
  puntosGPS: string;
  sesionesIGAC: string;
};

type Company = {
  nombreComercial: string;
  experiencia: string;
  ubicacion: string;
  mision: string;
  vision: string;
  valores: string[];
};

const metrics = metricsData as Metrics;
const company = companyData as Company;

const metricItems = [
  { key: 'kilometrosMedidos', label: 'km medidos' },
  { key: 'regionesAtendidas', label: 'regiones atendidas' },
  { key: 'puntosGPS', label: 'puntos GPS' },
  { key: 'sesionesIGAC', label: 'sesiones IGAC' },
] as const;
---

<section id="nosotros" class="section bg-white">
  <div class="container-custom grid items-start gap-10 lg:grid-cols-2">
    <div class="reveal">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary-600">Sobre ECOSURVEY</p>
      <h2 class="mb-4 font-display text-3xl font-bold text-neutral-900 md:text-4xl">{company.nombreComercial}</h2>
      <p class="mb-6 text-neutral-600">{company.experiencia} • {company.ubicacion}</p>

      <div class="mb-6 space-y-4">
        <article class="glass p-5">
          <h3 class="mb-2 text-xl font-semibold text-neutral-900">Misión</h3>
          <p class="text-sm leading-relaxed text-neutral-700">{company.mision}</p>
        </article>
        <article class="glass p-5">
          <h3 class="mb-2 text-xl font-semibold text-neutral-900">Visión</h3>
          <p class="text-sm leading-relaxed text-neutral-700">{company.vision}</p>
        </article>
      </div>

      <div class="flex flex-wrap gap-2">
        {company.valores.map((valor) => (
          <span class="rounded-full border border-primary-200 bg-primary-50 px-3 py-1 text-xs font-semibold text-primary-700">
            {valor}
          </span>
        ))}
      </div>

      <p class="mt-6 inline-flex rounded-full bg-primary-600 px-3 py-1 text-xs font-semibold text-white">
        Registro RAA activo
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4 reveal">
      {metricItems.map((item) => (
        <article class="card p-5 text-center">
          <p class="counter text-3xl font-bold text-primary-600 md:text-4xl" data-target={metrics[item.key]}>
            {metrics[item.key]}
          </p>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wide text-neutral-600">{item.label}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const parseMetricValue = (raw: string) => {
    const value = raw.replace(/[^\d]/g, '');
    return Number.parseInt(value || '0', 10);
  };

  const formatMetricValue = (raw: string, value: number) => {
    if (raw.includes('km')) return `+${value.toLocaleString('es-CO')} km`;
    if (raw.includes('regiones')) return `+${value.toLocaleString('es-CO')} regiones`;
    if (raw.includes('puntos')) return `+${value.toLocaleString('es-CO')} puntos`;
    if (raw.includes('sesiones')) return `+${value.toLocaleString('es-CO')} sesiones`;
    return `+${value.toLocaleString('es-CO')}`;
  };

  const counters = Array.from(document.querySelectorAll<HTMLElement>('.counter'));
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const el = entry.target as HTMLElement;
        const rawTarget = el.dataset.target ?? '+0';
        const targetValue = parseMetricValue(rawTarget);
        let current = 0;
        const duration = 1200;
        const step = Math.max(1, Math.floor(targetValue / (duration / 16)));

        const timer = window.setInterval(() => {
          current += step;
          if (current >= targetValue) {
            current = targetValue;
            window.clearInterval(timer);
          }
          el.textContent = formatMetricValue(rawTarget, current);
        }, 16);

        observer.unobserve(el);
      });
    },
    { threshold: 0.4 }
  );

  counters.forEach((counter) => observer.observe(counter));
</script>
